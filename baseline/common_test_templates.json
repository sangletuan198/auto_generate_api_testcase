  "error_body_mod_heuristics": {
    "_comment": "Pattern → body_mod mapping for auto-generating ERR cases from api_errors. Keys are regex patterns matched against error key names.",
    "rules": [
      {
        "pattern": "CIF.*NOT_FOUND",
        "field_candidates": ["cifNo", "cif"],
        "value": "99999999",
        "description_template": "Non-existent CIF triggers {err_key}"
      },
      {
        "pattern": "CIF.*INVALID|INVALID.*CIF",
        "field_candidates": ["cifNo", "cif"],
        "value": "INVALID_CIF_XYZ",
        "description_template": "Invalid CIF format triggers {err_key}"
      },
      {
        "pattern": "(ACC|ACCOUNT).*(NOT_FOUND|NOT_DOUND)",
        "field_candidates": ["accNo", "aaAccount"],
        "value": "999999999999",
        "description_template": "Non-existent account triggers {err_key}"
      },
      {
        "pattern": "(ACC|ACCOUNT).*INVALID",
        "field_candidates": ["accNo", "aaAccount"],
        "value": "!@#$%^",
        "description_template": "Invalid account format triggers {err_key}"
      },
      {
        "pattern": "TIMEOUT",
        "field_candidates": [],
        "value": null,
        "description_template": "Server timeout scenario for {err_key}"
      },
      {
        "pattern": "FUNCTIONCODE|FUNCTION_CODE",
        "field_candidates": [],
        "value": null,
        "description_template": "Invalid function code triggers {err_key}"
      },
      {
        "pattern": "BACKEND|ERROR_IN",
        "field_candidates": ["{f1}"],
        "value": "__REPEAT_DEL_50__",
        "description_template": "Backend error triggered by corrupt data ({err_key})"
      }
    ],
    "fallback": {
      "description_template": "Trigger {err_key} with invalid value",
      "use_remove_mandatory": true,
      "fallback_value_prefix": "TRIGGER_ERROR_"
    }
  },

